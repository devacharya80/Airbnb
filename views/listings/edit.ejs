<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>WanderLust</title>
  </head>
  <body>
    <h3>Edit your Lisiting</h3>
    <form action="/listings<%= listing.id %>?_method=PUT" method="post">
      <input
        type="text"
        name="listing[title]"
        id="title"
        value="<%= listing.title %>"
      />
      <br /><br />
      <textarea type="text" name="listing[description]" id="description">
        <%= listing.description %></textarea
      >
      <br /><br />
      <input
        type="text"
        name="listing[image]"
        id="image"
        value="<%= listing.image %>"
      />
      <br /><br />
      <input
        type="number"
        name="listing[price]"
        id="price"
        value="<%= listing.price %>"
      />
      <br /><br />
      <input
        type="text"
        name="listing[location]"
        id="location"
        value="<%= listing.location %>"
      />
      <br /><br />
      <input
        type="text"
        name="listing[country]"
        id="country"
        value="<%= listing.country %>"
      />
      <br /><br />
      <button>Edit</button>
    </form>
  </body>
</html>
