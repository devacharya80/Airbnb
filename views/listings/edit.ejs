<% layout('layouts/boilerplate.ejs') %>
<body>
  <div class="row">
    <div class="col-8 offset-2 mt-3 mb -3">
      <h3>Edit your Lisiting</h3>
      <form
        action="/listings/<%= listing.id %>?_method=PUT"
        method="post"
        class="needs-validation"
        novalidate
      >
        <div class="mt-3">
          <label for="title" class="form-label">Title</label>
          <input
            type="text"
            name="listing[title]"
            id="title"
            value="<%= listing.title %>"
            class="form-control"
            required
          />
          <div class="valid-feedback">Looks good!</div>
          <div class="invalid-feedback">Enter a valid Title</div>
        </div>

        <div class="mt-3">
          <label for="description" class="form-label">Description</label>
          <textarea
            type="text"
            name="listing[description]"
            id="description"
            class="form-control"
            required
          >
          <%= listing.description %></textarea
          >
          <div class="valid-feedback">Looks good!</div>
          <div class="invalid-feedback">Enter a valid Description</div>
        </div>

        <div class="mt-3">
          <label for="image" class="form-label">Image</label>
          <input
            type="text"
            name="listing[image]"
            id="image"
            class="form-control"
            placeholder="Upload Image"
            required
          />
        </div>

        <div class="mt-3">
          <label for="price" class="form-label">Price</label>
          <input
            type="number"
            name="listing[price]"
            id="price"
            class="form-control"
            value="<%= listing.price %>"
            min="0"
            required
          />
          <div class="valid-feedback">Looks good!</div>
          <div class="invalid-feedback">Enter a valid Price</div>
        </div>

        <div class="row">
          <div class="mt-3 col-md-4">
            <label for="location" class="form-label">Location</label>
            <input
              type="text"
              name="listing[location]"
              id="location"
              placeholder="Enter location"
              class="form-control"
              value="<%= listing.location %>"
              required
            />
            <div class="valid-feedback">Looks good!</div>
            <div class="invalid-feedback">Enter a valid Location</div>
          </div>
          <div class="mt-3 col-md-8">
            <label for="country" class="form-label">Country</label>
            <input
              type="text"
              name="listing[country]"
              id="country"
              placeholder="Enter country"
              class="form-control"
              value="<%= listing.country %>"
              required
            />
            <div class="valid-feedback">Looks good!</div>
            <div class="invalid-feedback">Enter a valid Country</div>
          </div>
        </div>
        <button class="btn btn-dark edit-btn mt-4 mb-3">Edit</button>
      </form>
    </div>
  </div>
</body>
