<% layout('layouts/boilerplate.ejs') %>
<body>
  <div class="row mt-3">
    <div class="col-8 offset-2 mt-3 mb-3">
      <h3>Create a New Lisiting</h3>
      <form
        action="/listings"
        method="post"
        class="needs-validation"
        novalidate
        enctype="multipart/form-data"
      >
        <div class="mt-3">
          <label for="title" class="form-label">Title</label>
          <input
            type="text"
            name="listing[title]"
            id="title"
            placeholder="Enter title"
            class="form-control"
            required
          />
          <div class="valid-feedback">Looks good!</div>
          <div class="invalid-feedback">Enter a valid Title</div>
        </div>
        <div class="mt-3">
          <label for="description" class="form-label">Description</label>
          <textarea
            type="text"
            name="listing[description]"
            id="description"
            placeholder="Enter description"
            class="form-control"
            required
          ></textarea>
          <div class="valid-feedback">Looks good!</div>
          <div class="invalid-feedback">Enter a valid Description</div>
        </div>
        <div class="mt-3">
          <label for="image" class="form-label">Image</label>
          <input
            type="file"
            name="listing[image]"
            id="image"
            placeholder="Enter image link"
            class="form-control"
            required
          />
        </div>
        <div class="mt-3">
          <label for="image" class="form-label">Price</label>
          <input
            type="number"
            name="listing[price]"
            id="price"
            placeholder="Enter price"
            class="form-control"
            min="0"
            required
          />
          <div class="valid-feedback">Looks good!</div>
          <div class="invalid-feedback">Enter a valid Price</div>
        </div>
        <div class="row">
          <div class="mt-3 col-md-4">
            <label for="location" class="form-label">Location</label>
            <input
              type="text"
              name="listing[location]"
              id="location"
              placeholder="Enter location"
              class="form-control"
              required
            />
            <div class="valid-feedback">Looks good!</div>
            <div class="invalid-feedback">Enter a valid Location</div>
          </div>
          <div class="mt-3 col-md-8">
            <label for="country" class="form-label">Country</label>
            <input
              type="text"
              name="listing[country]"
              id="country"
              placeholder="Enter country"
              class="form-control"
              required
            />
            <div class="valid-feedback">Looks good!</div>
            <div class="invalid-feedback">Enter a valid Country</div>
          </div>
        </div>
        <button class="btn btn-dark add-btn mt-3">Add</button>
      </form>
    </div>
  </div>
</body>
